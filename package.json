    "@react-three/fiber": "^9.6.1",
    "@streamdown/math": "^1.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "gsap": "^3.15.0",
    "katex": "^0.17.0",
    "lenis": "^1.2.3",
    "lucide-react": "^0.553.0",
    "motion": "^12.40.0",
    "ogl": "^1.0.11",
    "openai": "^6.37.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.15.0",

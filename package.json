{
  "name": "teach-me",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5174",
    "server": "node --env-file=.env.local server/server.mjs",
    "start:voice": "node server/server.mjs",
    "create:speech-engine": "node --env-file=.env.local server/create-speech-engine.mjs",
    "build": "tsc --noEmit && vite build",

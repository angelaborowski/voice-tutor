{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "echo \"No build step for the voice server\""
  },
  "deploy": {
    "startCommand": "npm run start:voice",
    "healthcheckPath": "/api/health",
